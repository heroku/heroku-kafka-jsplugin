{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node"],
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "commands/**/*",
    "lib/**/*",
    "test/**/*",
    "types/**/*",
    "index.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage"
  ]
}
